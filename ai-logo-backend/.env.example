# 后端环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ========================================
# DeepSeek API 配置
# ========================================
# DeepSeek API 密钥 (必填)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础URL (可选，默认值如下)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ========================================
# KIEAI API 配置
# ========================================
# KIEAI API 密钥 (必填)
# 获取地址: https://www.kie.ai/
KIEAI_API_KEY=your_kieai_api_key_here

# KIEAI API 基础URL (可选，默认值如下)
KIEAI_BASE_URL=https://api.kie.ai

# ========================================
# 服务器配置
# ========================================
# 后端服务器端口 (可选，默认 3001)
PORT=3001

# ========================================
# 说明
# ========================================
# 1. 此文件仅用于后端服务 (ai-logo-backend)
# 2. 不要将真实的 API 密钥提交到 Git
# 3. 部署到生产环境时，在服务器或平台中配置这些环境变量

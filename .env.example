# 前端环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# ========================================
# 后端 API 地址配置
# ========================================
# 本地开发环境
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# 生产环境示例 (部署到 Vercel 时需要修改为实际的后端 API 地址)
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-api.vercel.app

# ========================================
# 说明
# ========================================
# - NEXT_PUBLIC_ 前缀的环境变量会暴露给浏览器端
# - 部署到 Vercel 时，在项目设置中配置此环境变量
# - 后端 API 需要单独部署（可以是 Vercel Serverless Functions 或独立服务器）

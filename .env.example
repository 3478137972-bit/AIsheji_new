# 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# ========================================
# API 配置 (可选)
# ========================================
# 如果需要使用外部后端 API，可以配置此变量
# 留空则使用 Next.js 内置的 API Routes
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-api.com

# ========================================
# DeepSeek API 配置 (必填)
# ========================================
# DeepSeek API 密钥
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础URL (可选，默认值如下)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ========================================
# KIEAI API 配置 (必填)
# ========================================
# KIEAI API 密钥
# 获取地址: https://www.kie.ai/
KIEAI_API_KEY=your_kieai_api_key_here

# KIEAI API 基础URL (可选，默认值如下)
KIEAI_BASE_URL=https://api.kie.ai

# ========================================
# Supabase 配置 (必填)
# ========================================
# Supabase 项目 URL
# 获取地址: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Supabase 匿名密钥 (公开密钥，可以暴露给浏览器)
# 获取地址: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase 服务端密钥 (私密密钥，仅用于服务端)
# 获取地址: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ========================================
# 说明
# ========================================
# - NEXT_PUBLIC_ 前缀的环境变量会暴露给浏览器端
# - 后端 API 密钥不要使用 NEXT_PUBLIC_ 前缀，仅在服务端使用
# - 部署到 Vercel 时，在项目设置中配置这些环境变量
# - 本地开发时，将此文件复制为 .env.local 并填写真实值
# - Supabase Auth 需要配置 Google OAuth: https://supabase.com/dashboard/project/YOUR_PROJECT/auth/providers
